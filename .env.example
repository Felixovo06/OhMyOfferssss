POSTGRES_DB=ohmyoffer
POSTGRES_USER=ohmyoffer
POSTGRES_PASSWORD=change-this-postgres-password

JWT_SECRET=change-this-to-at-least-32-random-bytes
BACKEND_CORS_ORIGINS=http://localhost,http://127.0.0.1
SECURE_COOKIES=false

WEB_PORT=80
API_PORT=8000

LLM_MODEL=deepseek-v4-flash
LLM_THINKING_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_API_BASE_URL=https://open.feishu.cn/open-apis
FEISHU_TOKEN_CACHE_TTL_SECONDS=6600

GITHUB_PROXY_URL=

# Use these only with docker-compose.external.yml.
# DATABASE_URL=postgresql+psycopg://postgres:password@your-db-host:5432/postgres
# REDIS_URL=redis://:password@your-redis-host:6379/0
