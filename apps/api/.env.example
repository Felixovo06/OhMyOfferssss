APP_NAME="Ohmyoffer API"
ENVIRONMENT=local
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Local defaults. Replace credentials in your private .env only.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ohmyoffer
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
AUTH_COOKIE_NAME=ohmyoffer_access_token
SECURE_COOKIES=false

LLM_MODEL=deepseek-v4-flash
LLM_THINKING_ENABLED=false
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.deepseek.com

FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your-feishu-secret
FEISHU_API_BASE_URL=https://open.feishu.cn/open-apis
FEISHU_TOKEN_CACHE_TTL_SECONDS=6600
