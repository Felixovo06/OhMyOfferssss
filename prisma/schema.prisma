generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  memberships  GroupMember[]
  ownedGroups   Group[]         @relation("GroupOwner")
  sentInvitations GroupInvitation[] @relation("InvitationSender")
  invitations   GroupInvitation[] @relation("InvitationRecipient")
  questionBanks QuestionBank[]   @relation("QuestionBankOwner")
  questions     Question[]      @relation("QuestionOwner")
}

model Group {
  id           String          @id @default(cuid())
  name         String
  ownerId      String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  owner        User            @relation("GroupOwner", fields: [ownerId], references: [id])
  members      GroupMember[]
  invitations  GroupInvitation[]
  questionBanks QuestionBank[]
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      GroupMemberRole @default(MEMBER)
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model GroupInvitation {
  id           String   @id @default(cuid())
  token        String   @unique
  groupId      String
  inviterId    String
  recipientEmail String?
  status       GroupInvitationStatus @default(PENDING)
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter   User  @relation("InvitationSender", fields: [inviterId], references: [id], onDelete: Cascade)
  recipient User? @relation("InvitationRecipient", fields: [recipientEmail], references: [email])
}

model QuestionBank {
  id        String   @id @default(cuid())
  name      String
  scope     QuestionBankScope
  groupId   String?
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  questions Question[]
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  owner     User     @relation("QuestionBankOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([scope])
  @@index([groupId])
  @@index([ownerId])
}

model Question {
  id              String       @id @default(cuid())
  bankId          String
  ownerId         String
  question        String
  answer          String
  difficultyScore Int
  enabled         Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  bank            QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)
  owner           User         @relation("QuestionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tags            QuestionTag[]

  @@index([bankId])
  @@index([ownerId])
  @@index([enabled])
  @@index([difficultyScore])
}

model Tag {
  id        String        @id @default(cuid())
  name      String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  questions QuestionTag[]
}

model QuestionTag {
  questionId String
  tagId      String
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
  @@index([tagId])
}

enum GroupMemberRole {
  OWNER
  MEMBER
}

enum GroupInvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELED
}

enum QuestionBankScope {
  PERSONAL
  GROUP
}
